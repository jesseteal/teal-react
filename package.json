{
  "name": "@jesseteal/teal-react",
  "version": "3.0.0-c",
  "description": "A bundle of reusable React files for re-use in my projects.",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "import": "./dist/hooks/index.js"
    },
    "./mui": {
      "types": "./dist/mui/index.d.ts",
      "import": "./dist/mui/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js"
    },
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jesseteal/teal-react.git"
  },
  "author": "Jesse Teal",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/jesseteal/teal-react/issues"
  },
  "homepage": "https://github.com/jesseteal/teal-react#readme",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "example": "vite --config example/vite.config.ts",
    "example:build": "vite build --config example/vite.config.ts",
    "example:preview": "vite preview --config example/vite.config.ts",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "tsc --noEmit",
    "validate:package": "pnpm build && node ./scripts/validate-package.mjs",
    "prepack": "pnpm typecheck && pnpm exec jest --runInBand --watchman=false && pnpm validate:package",
    "test": "jest --watchman=false"
  },
  "dependencies": {
    "jwt-decode": "^3.1.2",
    "moment": "^2.30.1",
    "validate.js": "^0.13.1"
  },
  "peerDependencies": {
    "@emotion/react": "^11.5.0",
    "@emotion/styled": "^11.3.0",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "@mui/x-date-pickers": "^9.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.5",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.0.1",
    "@mui/material": "^9.0.1",
    "@mui/x-date-pickers": "^9.3.0",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^13.5.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.19.19",
    "@types/react": "^18.3.29",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.2",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-mock-fetch": "^2.0.5",
    "prettier": "^3.8.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ts-jest": "^29.4.11",
    "typescript": "^4.9.5",
    "vite": "^8.0.14"
  }
}
