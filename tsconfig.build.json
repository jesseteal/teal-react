{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowJs": false,
    "declaration": true,
    "declarationMap": false,
    "emitDeclarationOnly": false,
    "module": "node16",
    "moduleResolution": "node16",
    "noEmit": false,
    "outDir": "./dist",
    "rootDir": "./src",
    "sourceMap": false
  },
  "include": ["src"],
  "exclude": [
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx",
    "src/**/__test__/**/*",
    "dist",
    "example",
    "__mocks__",
    "jest-setup.ts"
  ]
}
